# 服务端口
PORT=3001

# 飞书应用凭证 (从飞书开放平台获取 https://open.feishu.cn/app)
# 【安全警告】切勿把真实 secret 写入本模板文件, 真实值只应写在 .env 里
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书消息接收者
# FEISHU_RECEIVE_ID_TYPE 可选: open_id / union_id / user_id / email / chat_id
# 若 FEISHU_RECEIVE_ID 形如 oc_xxx 请填 chat_id；形如 ou_xxx 请填 open_id；形如 on_xxx 请填 union_id
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=oc_your_chat_id_here

# 配置接口鉴权 Token (前端/Postman 修改配置/解锁时需要带 X-Auth-Token 请求头)
# 强烈建议设置为不易猜测的随机长字符串
CONFIG_AUTH_TOKEN=please_change_me_to_a_long_random_string

# 策略参数 (可选, 有默认值)
# 最小回落/反弹幅度 (相对于阻力价/支撑价的百分比), 例如 0.0005 = 0.05%
MIN_REVERSAL_PCT=0.0005
# 触发假突破/跌破所需的连续确认次数 (避免单次tick抖动误触发)
CONFIRM_COUNT=2
# Webhook 请求超时 (毫秒)
WEBHOOK_TIMEOUT_MS=10000
# 币安接口请求超时 (毫秒)
BINANCE_TIMEOUT_MS=10000

# SSRF 防御: 默认拒绝 webhookUrl 指向内网/回环地址 (localhost, 127.*, 10.*, 172.16-31.*, 192.168.*, 169.254.*)
# 仅当你确实需要把交易中间件部署在内网时, 才把它设为 true
ALLOW_INTERNAL_WEBHOOK=false

# ============ 日内超短线 - 近1H 瞬时费率均值铁律 ============
# 核心铁律: 过去 1 小时瞬时预测费率的平均值方向决定开仓方向
#   均值 > +RATE1H_MIN_ABS  →  多头拥挤, 可做空 (假突破回落时)
#   均值 < -RATE1H_MIN_ABS  →  空头拥挤, 可做多 (假跌破反弹时)
#   |均值| <= RATE1H_MIN_ABS →  市场中性, 不开仓
#
# 最小均值绝对值阈值. 0.00005 = 0.5bp (推荐, 过滤微弱噪声)
#   0.00003 = 偏宽松 (更多信号, 噪声略多)
#   0.0001  = 严格 (0.01%, 只跟明显的情绪拥挤)
RATE1H_MIN_ABS=0.00005

# 最少需要多少个采样点才视为 1H 均值有效 (避免刚启动时信号不稳)
# 默认 10 个 (每 90 秒采样一次, 约 15 分钟暖机)
# 如果你希望启动后更快进入信号状态, 可以调小 (比如 3)
RATE1H_MIN_SAMPLES=10
