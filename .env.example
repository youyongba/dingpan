# 服务端口
PORT=3001

# 飞书应用凭证 (从飞书开放平台获取 https://open.feishu.cn/app)
# 【安全警告】切勿把真实 secret 写入本模板文件, 真实值只应写在 .env 里
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书消息接收者
# FEISHU_RECEIVE_ID_TYPE 可选: open_id / union_id / user_id / email / chat_id
# 若 FEISHU_RECEIVE_ID 形如 oc_xxx 请填 chat_id；形如 ou_xxx 请填 open_id；形如 on_xxx 请填 union_id
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=oc_your_chat_id_here

# 清空历史数据接口 (/api/reset) 的鉴权 Token, 防止外人刷接口
# 建议设置为不易猜测的随机长字符串
CONFIG_AUTH_TOKEN=please_change_me_to_a_long_random_string

# 币安接口请求超时 (毫秒)
BINANCE_TIMEOUT_MS=10000

# ============ 近 1H 瞬时费率均值拥挤阈值 ============
# 均值 > +RATE1H_MIN_ABS  → 多头拥挤 (可做空)
# 均值 < -RATE1H_MIN_ABS  → 空头拥挤 (可做多)
# |均值| <= RATE1H_MIN_ABS → 市场中性
#
# 0.00005 = 0.5bp (推荐)
# 0.00003 = 偏宽松
# 0.0001  = 严格 (1bp)
RATE1H_MIN_ABS=0.00005

# 1H 均值生效所需最少采样点数 (每 90s 一个点, 10 = 约 15 分钟暖机)
# 启动后更快进入信号状态可调小, 比如 3
RATE1H_MIN_SAMPLES=10
