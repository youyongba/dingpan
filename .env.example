# 服务端口
PORT=3001

# 飞书应用凭证 (从飞书开放平台获取 https://open.feishu.cn/app)
# 【安全警告】切勿把真实 secret 写入本模板文件, 真实值只应写在 .env 里
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书消息接收者
# FEISHU_RECEIVE_ID_TYPE 可选: open_id / union_id / user_id / email / chat_id
# 若 FEISHU_RECEIVE_ID 形如 oc_xxx 请填 chat_id；形如 ou_xxx 请填 open_id；形如 on_xxx 请填 union_id
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=oc_your_chat_id_here

# 清空历史数据接口 (/api/reset) 的鉴权 Token, 防止外人刷接口
# 建议设置为不易猜测的随机长字符串
CONFIG_AUTH_TOKEN=please_change_me_to_a_long_random_string

# 币安接口请求超时 (毫秒)
BINANCE_TIMEOUT_MS=10000

# ============ 近 1H 瞬时费率均值拥挤阈值 ============
# 均值 > +RATE1H_MIN_ABS  → 多头拥挤 (可做空)
# 均值 < -RATE1H_MIN_ABS  → 空头拥挤 (可做多)
# |均值| <= RATE1H_MIN_ABS → 市场中性
#
# 0.00005 = 0.5bp (推荐)
# 0.00003 = 偏宽松
# 0.0001  = 严格 (1bp)
RATE1H_MIN_ABS=0.00005

# 1H 均值生效所需最少采样点数 (每 90s 一个点, 10 = 约 15 分钟暖机)
# 启动后更快进入信号状态可调小, 比如 3
RATE1H_MIN_SAMPLES=10

# ============ Regime 宏观监控模块配置 ============
# 是否启用 regime 模块的飞书推送 (0 = 关闭, 其他 = 开启)
REGIME_FEISHU_ENABLED=1

# Regime 模块连续拉取失败多少次后推送告警
REGIME_FAIL_ALERT_THRESHOLD=3

# 只要你 不写 TRADING_NOTIFY_TG=1 ，Telegram 就 绝对不会 收到那些流水账消息（比如平仓、触发止盈止损等）。
TRADING_NOTIFY_TG=0

# ============ 通知状态持久化文件路径 (重启后不重复推送) ============
# 相对路径相对项目根, 默认会落在 ./data/ 下
# REGIME_NOTIFY_STATE_PATH=./data/regime_notify_state.json
# FUNDING_NOTIFY_STATE_PATH=./data/funding_notify_state.json

# ============ 飞书自定义机器人 Webhook 推送 (新版 Regime 关键信号) ============
# 触发场景：
#   - Regime 细分状态切换（强多头/弱多头/震荡/弱空头/强空头/恐慌）
#   - MACD 金叉 / 死叉
#   - RSI 进入超买(>=70) / 超卖(<=30) 区
#
# 如何获取 URL:
#   飞书群 → 设置 → 群机器人 → 添加机器人 → "自定义机器人"
#   复制 webhook 地址粘贴到这里。
#   若勾选了 "签名校验"，请同时填 FEISHU_WEBHOOK_SECRET。
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# 是否启用 Webhook (0 = 关闭, 其他 = 开启, 默认开启)
WEBHOOK_ENABLED=1

# 全局最小推送间隔 (毫秒)：任意两条 Webhook 消息之间至少间隔这么久
# 默认 30000 (30s), 避免 Webhook 被频繁调用
WEBHOOK_MIN_INTERVAL_MS=30000

# 同类事件冷却 (毫秒)：同一事件 key (regimeChange / macdCross_GOLDEN / rsiZone_OVERBOUGHT 等)
# 在冷却期内不会重复推送, 默认 300000 (5min)
WEBHOOK_EVENT_COOLDOWN_MS=300000

# ============ Telegram VIP 群组「交易信号」推送 ============
# 仅在交易动作切换 (转入做多/做空/观望) 时推送, 内容仅含交易参数
# 机器人需要：
#   1) 通过 BotFather 创建并拿到 token
#   2) 加入目标群组并被设置为「管理员」(开启发消息、踢人权限)
#   3) 群组若是超级群组 (supergroup), chat_id 为 -100 开头的负数
TELEGRAM_BOT_TOKEN=
TELEGRAM_VIP_GROUP_ID=

# 关闭推送：设为 0
TELEGRAM_PUSH_ENABLED=1
# 单次推送超时 (毫秒)
TELEGRAM_TIMEOUT_MS=8000

# ============ 自动平仓引擎 (trading 模块) ============
# 启动后默认监听 BTCUSDT.P, 接收外部 webhook 信号 → 登记仓位 → WS 价格触发 TP/SL → 出站 webhook
# 路由: POST /api/auto-trade/signal  /reset  GET /status /config
#
# 出站 webhook (即外部交易执行端入口) 与校验 token, 已内置默认值:
#   webhookUrl = https://transpenetrable-shantel-unabortively.ngrok-free.dev/webhook/wh_d113d9b4d838dbd635d4c19c3f0c51d9
#   token      = wh_d113d9b4d838dbd635d4c19c3f0c51d9
# 想覆盖请取消下面注释:
# AUTO_TRADE_WEBHOOK_URL=https://your-domain/webhook/xxx
# AUTO_TRADE_WEBHOOK_TOKEN=wh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AUTO_TRADE_ENABLED=1                     # 设为 0 临时停用风控
# AUTO_TRADE_CONFIG_PATH=./data/auto_trade_config.json
# AUTO_TRADE_STATE_PATH=./data/auto_trade_state.json

# --- Binance WebSocket 代理 (中国大陆/境内服务器必填) ---
# 不配置代理时, 会出现 "Opening handshake has timed out", 因为直连无法到达 fstream.binance.com
# 支持 http(s):// 和 socks5://
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=socks5://127.0.0.1:1080
#
# (可选) 自定义 WS 节点 / 握手超时 (默认 20000ms):
# BINANCE_WS_BASE=wss://fstream.binance.com/ws
# BINANCE_WS_HANDSHAKE_MS=20000
#
# 注：实际运行时配置以 data/auto_trade_config.json 为准 (后台 POST /api/auto-trade/config 可热更新)
